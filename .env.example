# ─────────────────────────────────────────────────────────────────────────────
# Ibis Logistics Extractor — Environment Variables
#
# Copy this file to .env and fill in your values for local development.
# In production (Vercel / Docker), set these directly in the environment.
# NEVER commit .env to source control.
# ─────────────────────────────────────────────────────────────────────────────

# [REQUIRED] Google AI Studio API key — get one at https://ai.google.dev/
GEMINI_API_KEY=your_gemini_api_key_here

# [OPTIONAL] Maximum accepted upload size in bytes (default: 52428800 = 50 MB)
# MAX_FILE_BYTES=52428800

# [OPTIONAL] API rate limit in slowapi format: "N/period"
# Examples: "10/minute", "100/hour", "1000/day"
# Note: in-process limiting does not persist across Vercel serverless invocations.
# RATE_LIMIT=10/minute

# [OPTIONAL] Comma-separated list of allowed CORS origins, or "*" for all.
# Example: "https://app.ibislabs.com,https://staging.ibislabs.com"
# ALLOWED_ORIGINS=*

# [OPTIONAL] Log output format
# "json"  — structured JSON lines, suitable for Datadog / CloudWatch / Vercel Log Drains
# "text"  — human-readable, suitable for local development
# LOG_FORMAT=json
