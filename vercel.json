{
  "builds": [
    {
      "src": "api/extract.py",
      "use": "@vercel/python",
      "config": {
        "maxDuration": 60
      }
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/static/$1"
    },
    {
      "src": "/api/(.*)",
      "dest": "api/extract.py"
    },
    {
      "src": "/(.*)",
      "dest": "api/extract.py"
    }
  ]
}
