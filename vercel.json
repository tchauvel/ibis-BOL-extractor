{
  "functions": {
    "api/extract.py": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/static/(.*)",
      "destination": "/static/$1"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/extract.py"
    },
    {
      "source": "/((?!api/|static/).*)",
      "destination": "/api/extract.py"
    }
  ]
}
