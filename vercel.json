{
  "builds": [
    {
      "src": "api/extract.py",
      "use": "@vercel/python",
      "config": {
        "maxDuration": 60
      }
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "api/extract.py"
    },
    {
      "source": "/(.*)",
      "destination": "api/extract.py"
    }
  ]
}
